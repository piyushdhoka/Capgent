# Capgent API base URL
CAPAGENT_API_BASE_URL=http://127.0.0.1:8787

# OpenRouter API key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default LLM model for Grok sample (OpenRouter model ID)
OPENROUTER_MODEL=x-ai/grok-4-fast

# Optional: Gemini model (OpenRouter model ID for a Gemini 3.1 / 1.5 Pro variant)
# For example: google/gemini-1.5-pro-latest or your specific Gemini 3.1 model.
OPENROUTER_GEMINI_MODEL=google/gemini-3.0-flash-latest
