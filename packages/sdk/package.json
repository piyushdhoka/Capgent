{
  "name": "@capagent/sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./solver": {
      "types": "./dist/solver.d.ts",
      "default": "./dist/solver.js"
    },
    "./parser/heuristic": {
      "types": "./dist/parser/heuristic.d.ts",
      "default": "./dist/parser/heuristic.js"
    },
    "./parser/llm-openrouter": {
      "types": "./dist/parser/llmOpenRouter.d.ts",
      "default": "./dist/parser/llmOpenRouter.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "node -e \"console.log('no-op')\""
  },
  "dependencies": {}
}

