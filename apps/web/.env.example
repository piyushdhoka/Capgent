NEXT_PUBLIC_CAPAGENT_API_BASE_URL=http://127.0.0.1:8787

# Better Auth (for local development)
BETTER_AUTH_SECRET=dev-secret-change-me-please-change
BETTER_AUTH_URL=http://localhost:3000

# Admin key used by the web app to call Capgent project APIs.
# Must match CAPAGENT_ADMIN_API_KEY in apps/api/.env
CAPAGENT_ADMIN_API_KEY=dev-admin-key-change-me

