# Upstash Redis (required for challenge storage)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# JWT secret for signing proof tokens
CAPAGENT_JWT_SECRET=dev-secret-change-me

# Challenge & proof TTL
CAPAGENT_CHALLENGE_TTL_SECONDS=30
CAPAGENT_PROOF_TTL_SECONDS=300

# Public base URL of this API
CAPAGENT_PUBLIC_BASE_URL=http://localhost:8787

# Allowed CORS origins (comma-separated)
CAPAGENT_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
